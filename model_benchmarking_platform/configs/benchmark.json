{
  "experiment_name": "classification_model_benchmark",
  "random_seed": 42,
  "ranking_metric": "cv_f1_mean",
  "dataset": {
    "n_samples": 1000,
    "n_features": 20,
    "n_informative": 12,
    "n_redundant": 4,
    "n_classes": 2,
    "test_size": 0.2
  },
  "cross_validation": {
    "enabled": true,
    "n_splits": 5,
    "shuffle": true
  },
  "models": [
    {
      "name": "logistic_regression_baseline",
      "type": "logistic_regression",
      "params": {
        "max_iter": 1000,
        "solver": "liblinear"
      }
    },
    {
      "name": "decision_tree_baseline",
      "type": "decision_tree",
      "params": {
        "max_depth": 5,
        "random_state": 42
      }
    },
    {
      "name": "random_forest_baseline",
      "type": "random_forest",
      "params": {
        "n_estimators": 100,
        "max_depth": 8,
        "random_state": 42
      }
    }
  ]
}